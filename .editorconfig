root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{kt,kts}]
max_line_length = 140
indent_size = 4
continuation_indent_size = 4
# Jetpack Compose : les @Composable sont nommés en PascalCase par convention
ktlint_function_naming_ignore_when_annotated_with = Composable
