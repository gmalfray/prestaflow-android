<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission
        android:name="android.permission.POST_NOTIFICATIONS"
        tools:targetApi="tiramisu" />

    <!-- Bluetooth — imprimante thermique ESC/POS (MUNBYN ITPP941B et compatibles). -->
    <!-- API ≤ 30 : permissions classiques -->
    <uses-permission
        android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />
    <!-- API ≥ 31 (Android 12+) : permissions granulaires -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="s" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_CONNECT"
        tools:targetApi="s" />

    <application
        android:name=".core.PrestaFlowApp"
        android:allowBackup="false"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PrestaFlow"
        tools:targetApi="31">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.PrestaFlow">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Deep link pour les notifications "nouvelle commande" / statut / expédition.
                 La notification foreground (ContentIntent) envoie prestaflow://orders/{id} ;
                 le tap déclenche onNewIntent (singleTop) ou onCreate (cold start) dans MainActivity. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data
                    android:scheme="prestaflow"
                    android:host="orders" />
            </intent-filter>
        </activity>

        <service
            android:name=".data.push.PrestaFlowFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Notifs background sans channel_id explicite → canal sobre (son système, pas la caisse).
             Le module envoie le channel_id explicite pour les 3 catégories ; ceci n'est qu'un filet.
             Le canal est créé dans PrestaFlowApp via NotificationChannels.ensureAllChannels. -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="default_alerts" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_notification" />

        <!-- Scan QR verrouillé en portrait (la CaptureActivity ZXing par défaut force le paysage). -->
        <activity
            android:name=".ui.auth.PortraitCaptureActivity"
            android:screenOrientation="sensorPortrait"
            android:stateNotNeeded="true"
            android:exported="false"
            android:theme="@style/zxing_CaptureTheme" />

        <!-- FileProvider pour partager des PDFs (bordereau, facture) via Intent.ACTION_SEND.
             L'autorité utilise l'applicationId du flavor actif (prod / preprod / debug). -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
