    <!-- Module install guide screen -->
    <string name="module_guide_title">Module installation</string>
    <string name="module_guide_intro">The installation takes place on your computer, directly in your PrestaShop back office. Follow these 3 steps:</string>
    <string name="module_guide_step1_title">Download the module</string>
    <string name="module_guide_step1_desc">On your computer, go to the releases page (link below) and download the file rebuildconnector.zip (latest version).</string>
    <string name="module_guide_step2_title">Install via the back office</string>
    <string name="module_guide_step2_desc">In your PrestaShop back office → Modules → Upload a module → select the zip file and activate it.</string>
    <string name="module_guide_step3_title">Come back and connect</string>
    <string name="module_guide_step3_desc">Return to the app and scan the QR code displayed by the module (or enter the URL and key manually).</string>
