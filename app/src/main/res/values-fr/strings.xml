    <string name="module_guide_step2_title">Installer via le back-office</string>
    <string name="module_guide_step2_desc">Dans votre back-office PrestaShop → Modules → Installer un module → envoyez le fichier zip et activez-le.</string>
    <string name="module_guide_step3_title">Revenir et se connecter</string>
